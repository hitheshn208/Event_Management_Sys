<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Login - EventHub</title>
  <link rel="stylesheet" href="/css/login.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="container">
    <div class="login-form-wrapper">
      <!-- <a href="/" class="back-link">← Back</a> -->

      <div class="form-container">
        <div class="form-header">
          <h1>Student Login</h1>
          <p>Access your event dashboard</p>
        </div>

        <div id="error-message" class="error-message" aria-live="polite" style="display: none;"></div>

        <form method="POST" action="/auth/student-login" class="login-form" id="student-login-form">
          <div class="form-group">
            <label for="usn">USN</label>
            <input 
              type="text" 
              id="usn" 
              name="usn" 
              placeholder="1MS2XXXXXX"
              required
              autofocus
              autocomplete="off"
              style="text-transform: uppercase"
            >
            <small>Format: 1MS2XXXXXX (e.g., 1MS24CS001)</small>
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              placeholder="Enter your password"
              required
            >
          </div>

          <div class="form-group checkbox">
            <input type="checkbox" id="remember" name="remember">
            <label for="remember">Remember me</label>
          </div>

          <button type="submit" class="btn btn-primary btn-full">Login</button>
        </form>

        <div class="form-footer">
          <p>Don't have an account? <a href="/auth/student-register">Sign up as Student</a></p>
          <p>Forgot your password? <a href="/auth/forgot-password">Reset here</a></p>
        </div>

