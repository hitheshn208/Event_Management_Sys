<!-- Student Registration Page -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Registration | EventHub</title>
  <link rel="stylesheet" href="/css/login.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="container">
    <div class="login-form-wrapper">

      <div class="form-container">
        <div class="form-header">
          <h1>Student Registration</h1>
        </div>

        <div id="error-message" class="error-message" style="display: none; color: #e74c3c; padding: 10px; margin-bottom: 15px; background-color: #fadbd8; border: 1px solid #e74c3c; border-radius: 4px;"></div>

        <form id="student-register-form" class="login-form">

          <div class="form-group">
            <label for="usn">USN</label>
            <input
              type="text"
              id="usn" 
              name="usn" 
              placeholder="1MS2XXXXXX"
              autofocus
              required
              style="text-transform:uppercase"
            >
          </div>

          <div class="form-group">
            <label for="name">Name</label>
            <input
              type="text" 
              id="name" 
              name="name" 
              placeholder="Rishi"
              required
            >
          </div>

          <div class="form-group">
            <label for="phone">Phone</label>
            <input
              type="text"
              pattern="[0-9]{10}"
              id="phone"
              name="phone" 
              placeholder="Your 10 digit phone number"
              required
            >
          </div>

          <div class="form-group">
            <label for="email">University Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              placeholder="mail@university.edu"
              required
            >
            <small>Use your official university email address</small>
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              placeholder="Enter your password"
              required
            >
          </div>

          <button type="submit" class="btn btn-primary btn-full">Register</button>
        </form>

        <div class="form-footer">
          <p>Already have an account? <a href="/auth/student-login">Login with your student account</a></p>
        </div>

