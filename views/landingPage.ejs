<!-- Login Page after registeration to the platform -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EventHub - University Event Management</title>
  <link rel="stylesheet" href="css/landingpage.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="container">
    <div class="login-wrapper">
      <div class="header">
        <h1>EventHub</h1>
        <p class="subtitle">University Event Management Platform</p>
      </div>

      <div class="login-options">
        <div class="option-card student-card">
          <h2>Student</h2>
          <p>Discover, Register ,and never forget exciting university events</p>
          <a href="/auth/student-login" class="btn btn-primary">Student Login</a>
        </div>

        <div class="divider">OR</div>

        <div class="option-card organizer-card">
          <h2>Organizer</h2>
          <p>Publish and manage events for the your community</p>
          <a href="/auth/organizer-login" class="btn btn-secondary">Organizer Login</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
