<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Organization Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/css/orgdashboard.css">
</head>
<body>
    <%- include("partials/orgTopNav", { active: "home", profileName: "Organizer" }) %>

    <div class="org-dashboard-layout">
        <%- include("partials/orgSidebar", { active: "home" }) %>

        <main class="org-main-content">
            <section class="dashboard-headline">
                <h2>Your Hosted Events</h2>
                <p>Manage details and registrations for all your events from one place.</p>
            </section>

            <section class="events-list">
                <% if (!events || events.length === 0) { %>
                    <article class="event-card empty-state">
                        <h3>No events yet</h3>
                        <p>Start by hosting your first event.</p>
                        <a class="btn btn-primary" href="/organization/organise-event">Host Event</a>
                    </article>
                <% } %>

                <% if (events && events.length > 0) { %>
                    <% events.forEach((event) => { %>
                        <%
                            const eventDate = new Date(event.event_date);
                            const today = new Date();
                            let status = "UPCOMING";
                            let statusColor = "upcoming";
                            
                            if (eventDate < today) {
                                status = "COMPLETED";
                                statusColor = "completed";
                            }
                            
                            const registered = Number(event.registered || 0);
                            const capacity = Number(event.total_capacity || 0);
                            const registrationPercent = capacity > 0 ? Math.round((registered / capacity) * 100) : 0;
                        %>
                        <article class="event-card">
                            <div class="event-image-wrap">
                                <img src="<%= event.imgurl %>" alt="<%= event.name %> banner" loading="lazy" onerror="this.src='https://placehold.co/600x300/2d1148/e9dcff?text=Event+Image'" />
                            </div>

                            <div class="event-body">
                                <!-- Header with Title and Status -->
                                <div class="event-header">
                                    <div class="event-title-section">
                                        <h3><%= event.name %></h3>
                                        <span class="category-tag"><%= event.category %></span>
                                    </div>
                                    <span class="status-badge status-<%= statusColor %>"><%= status %></span>
                                </div>

                                <!-- Key Info Grid -->
                                <div class="event-meta-grid">
                                    <div class="meta-item">
                                        <i class="fa-solid fa-calendar-days"></i>
                                        <span><%= new Date(event.event_date).toLocaleDateString("en-IN", { day: "2-digit", month: "short", year: "numeric" }) %></span>
                                    </div>
                                    <div class="meta-item">
                                        <i class="fa-solid fa-clock"></i>
                                        <span><%= new Date(`1970-01-01T${event.event_time}`).toLocaleTimeString("en-IN", { hour: "numeric", minute: "2-digit", hour12: true }) %></span>
                                    </div>
                                    <div class="meta-item">
                                        <i class="fa-solid fa-location-dot"></i>
                                        <span><%= String(event.hall || "").replace(/_/g, " ").toUpperCase() %></span>
                                    </div>
                                    <div class="meta-item">
                                        <i class="fa-solid fa-users"></i>
                                        <span><%= event.isindividual ? "Individual" : "Team Event" %></span>
                                    </div>
                                </div>

                                <!-- Registration Progress -->
                                <div class="registration-section">
                                    <div class="registration-header">
                                        <span class="registration-label">Registrations</span>
                                        <span class="registration-count"><%= registered %>/<%= capacity %></span>
                                    </div>
                                    <div class="progress-bar">
                                        <div class="progress-fill" style="width: <%= registrationPercent%>%"></div>
                                    </div>
                                    <span class="progress-percent"><%= registrationPercent %>% capacity</span>
                                </div>

                                <!-- Action Buttons -->
                                <div class="card-actions">
                                    <a href="#" class="btn btn-secondary">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                        Edit
                                    </a>
                                    <a href="#" class="btn btn-primary">
                                        <i class="fa-solid fa-list-check"></i>
                                        Registrations
                                    </a>
                                    <a href="#" class="btn btn-secondary">
                                        <i class="fa-solid fa-qrcode"></i>
                                        Check-in
                                    </a>
                                    <a href="#" class="btn btn-secondary" onclick="return confirm('Are you sure you want to delete this event?');">
                                        <i class="fa-solid fa-trash"></i>
                                        Delete
                                    </a>
                                </div>
                            </div>
                        </article>
                    <% }) %>
                <% } %>
            </section>
        </main>
    </div>
</body>
</html>