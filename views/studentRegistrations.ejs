<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Registrations</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/css/student-dashboard.css">
</head>
<body>
    <%- include("partials/studentTopNav", { student, profileId: userId }) %>

    <main class="student-dashboard-main">
        <div class="student-dashboard-layout">
            <%- include("partials/studentSidebar", { activePage: "registrations" }) %>

            <section class="student-dashboard-content">
                <section class="student-dashboard-headline">
                    <h2>My registrations</h2>
                    <p>View your registered events and cancel your registration when needed.</p>
                </section>

                <section class="student-registrations-list">
                    <% if (!registrations || registrations.length === 0) { %>
                        <article class="student-event-card student-empty-state">
                            <h3>No registrations yet</h3>
                            <p>You have not registered for any event yet.</p>
                        </article>
                    <% } %>

                    <% if (registrations && registrations.length > 0) { %>
                        <% registrations.forEach((event) => { %>
                            <article class="student-event-card student-registration-card">
                                <div class="student-registration-card-main">
                                    <div class="student-registration-card-title-wrap">
                                        <h3><%= event.name %></h3>
                                        <span class="student-category-tag"><%= event.category %></span>
                                    </div>

                                    <div class="student-registration-card-meta">
                                        <div class="student-meta-item">
                                            <i class="fa-solid fa-calendar-days"></i>
                                            <span><%= new Date(event.event_date).toLocaleDateString("en-IN", { day: "2-digit", month: "short", year: "numeric" }) %></span>
                                        </div>
                                        <div class="student-meta-item">
                                            <i class="fa-solid fa-clock"></i>
                                            <span><%= new Date(`1970-01-01T${event.event_time}`).toLocaleTimeString("en-IN", { hour: "numeric", minute: "2-digit", hour12: true }) %></span>
                                        </div>
                                        <div class="student-meta-item">
                                            <i class="fa-solid fa-layer-group"></i>
                                            <span><%= event.category %></span>
                                        </div>
                                        <div class="student-meta-item">
                                            <i class="fa-solid fa-users"></i>
                                            <span><%= event.isindividual ? "Individual" : "Team" %></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="student-registration-card-side">
                                    <span class="student-status-tag student-status-<%= event.status %>">
                                        <%= event.status.charAt(0).toUpperCase() + event.status.slice(1) %>
                                    </span>
                                    <form method="POST" action="/student/event/<%= event.id %>/cancel" onsubmit="return confirm('Cancel registration for this event?')">
                                        <button type="submit" class="btn btn-secondary student-cancel-btn">
                                            <i class="fa-solid fa-xmark"></i>
                                            Cancel registration
                                        </button>
                                    </form>
                                </div>
                            </article>
                        <% }) %>
                    <% } %>
                </section>
            </section>
        </div>
    </main>

    <script src="/js/student-dashboard.js"></script>
</body>
</html>
